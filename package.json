{
  "name": "learn-x-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "npm run build:public",
    "build:public": "node app/code/scripts/build-static-data.mjs --target=public",
    "build:public:no-context": "LEARN_X_CHATPACK_CONTEXT=off node app/code/scripts/build-static-data.mjs --target=public --out-dir=dist/no-context",
    "build:local": "node app/code/scripts/build-static-data.mjs --target=local",
    "dev": "npm run build:local && node app/code/server.mjs",
    "test": "node --test app/code/scripts/*.test.mjs .agents/skills/learn-x-input/scripts/*.test.mjs .agents/skills/learn-x-process/scripts/*.test.mjs",
    "snapshot": "npm run build",
    "security:scan": "node scripts/security-scan.mjs",
    "security:scan:staged": "node scripts/security-scan.mjs --staged",
    "input:calendar": "node .agents/skills/learn-x-input/scripts/collect-calendar-weekly.mjs",
    "input:weread": "node .agents/skills/learn-x-input/scripts/collect-weread-weekly.mjs",
    "test:input:weread": "node --test .agents/skills/learn-x-input/scripts/collect-weread-weekly.test.mjs",
    "process:weekly": "node .agents/skills/learn-x-process/scripts/generate-weekly-process-pack.mjs",
    "process:monthly": "node .agents/skills/learn-x-process/scripts/generate-monthly-process-pack.mjs",
    "memory:weekly": "node .agents/skills/learn-x-process/scripts/prepare-weekly-memory.mjs",
    "memory:monthly": "node .agents/skills/learn-x-process/scripts/prepare-period-memory.mjs --month",
    "memory:yearly": "node .agents/skills/learn-x-process/scripts/prepare-period-memory.mjs --year",
    "test:app": "node --test app/code/scripts/*.test.mjs",
    "release": "node app/code/scripts/release.mjs",
    "input:build-bot": "node .agents/skills/build-bot-log/scripts/generate-build-bot.mjs",
    "wisdom-gate:ingest": "node .agents/skills/wisdom-gate/scripts/ingest.mjs",
    "research:ingest": "node .agents/skills/long-article-research/scripts/research-ingest.mjs"
  },
  "dependencies": {
    "dompurify": "^3.4.2",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.1.1"
  }
}
